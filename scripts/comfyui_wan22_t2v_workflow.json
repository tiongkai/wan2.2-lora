    "inputs": {"width": 512, "height": 768, "length": 33, "batch_size": 1}
  },
  "19": {
    "class_type": "KSamplerAdvanced",
    "_meta": {"title": "Sample high-noise (steps 0-10)"},
    "inputs": {
      "model": ["14", 0],
      "add_noise": "enable",
      "noise_seed": 42,
      "steps": 20,
      "cfg": 5.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "positive": ["6", 0],
      "negative": ["7", 0],
      "latent_image": ["18", 0],
      "start_at_step": 0,
      "end_at_step": 10,
      "return_with_leftover_noise": "enable"
    }
  },
  "20": {
    "class_type": "KSamplerAdvanced",
    "_meta": {"title": "Sample low-noise (steps 10-20)"},
    "inputs": {
      "model": ["15", 0],
      "add_noise": "disable",
      "noise_seed": 42,
      "steps": 20,
      "cfg": 5.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "positive": ["6", 0],
      "negative": ["7", 0],
      "latent_image": ["19", 0],
      "start_at_step": 10,
      "end_at_step": 10000,
      "return_with_leftover_noise": "disable"
    }
  },
  "21": {
    "class_type": "VAEDecode",
    "_meta": {"title": "VAE decode"},
    "inputs": {"samples": ["20", 0], "vae": ["17", 0]}
